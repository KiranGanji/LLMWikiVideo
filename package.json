{
  "name": "llm-wiki-video",
  "version": "1.0.0",
  "private": true,
  "description": "A Remotion explainer video for the UHG LLM Wiki concept.",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts Main out/llm-wiki-explainer.mp4 --codec=h264 --crf=18 --pixel-format=yuv420p",
    "render:4k": "remotion render src/index.ts Main out/llm-wiki-explainer-4k.mp4 --scale=2 --codec=h264 --crf=16",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.467",
    "@remotion/cli": "4.0.467",
    "@remotion/google-fonts": "4.0.467",
    "@remotion/noise": "4.0.467",
    "@remotion/tailwind": "4.0.467",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.467"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.18",
    "typescript": "5.9.3"
  }
}
